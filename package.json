{
  "name": "test-case-analysis",
  "displayName": "Test Case Analysis",
  "description": "A simple TypeScript VS Code extension with a custom sidebar view.",
  "version": "0.0.1",
  "publisher": "local",
  "icon": "images/icon.svg",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:testCaseAnalysis.selectFiles",
    "onCommand:testCaseAnalysis.profileTests",
    "onCommand:testCaseAnalysis.runTestsEfficiently",
    "onView:testCaseAnalysis.sidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "testCaseAnalysis.selectFiles",
        "title": "Test Case Analysis: Select Test Files"
      },
      {
        "command": "testCaseAnalysis.profileTests",
        "title": "Test Case Analysis: Profile Tests"
      },
      {
        "command": "testCaseAnalysis.runTestsEfficiently",
        "title": "Test Case Analysis: Run Tests Efficiently"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "testCaseAnalysis",
          "title": "Test Case Analysis",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "testCaseAnalysis": [
        {
          "id": "testCaseAnalysis.sidebarView",
          "name": "Test Case Analysis",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Test Case Analysis",
      "properties": {
        "testCaseAnalysis.testCommandTemplate": {
          "type": "string",
          "default": "node --test --test-name-pattern ${testNamePattern} ${relativeFile}",
          "description": "Command used to run one discovered test case. Use ${file}, ${relativeFile}, ${testName}, or ${testNamePattern} in the command."
        },
        "testCaseAnalysis.efficientRunCommandTemplate": {
          "type": "string",
          "default": "node --test --test-name-pattern ${testNamePattern} ${relativeFile}",
          "description": "Optional command used when running discovered test cases in shortest-first order. If empty, the test command template is reused."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.97.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.8.2"
  }
}
